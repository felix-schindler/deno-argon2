{
	"$schema": "https://deno.land/x/deno/cli/schemas/config-file.v1.json",
	"name": "@felix/argon2",
	"version": "3.0.3",
	"exports": "./mod.ts",
	"nodeModulesDir": "auto",
	"workspace": ["./benchmarks"],
	"tasks": {
		"samples": "deno run -A ./examples/with-options.ts && deno run -A ./examples/hash.ts && deno run -A ./examples/verify.ts",
		"ok": "deno fmt --check && deno lint && deno check **/*.ts",
		"test": "LOCAL=true deno test --allow-read --allow-write --allow-ffi --allow-run --allow-env tests/",
		"bench": "LOCAL=true deno bench --allow-read --allow-write --allow-ffi --allow-env benchmarks/",
		"build": "cargo build --release"
	},
	"imports": {
		"@denosaurs/plug": "jsr:@denosaurs/plug@^1.1.0",
		"@felix/argon2": "./mod.ts",
		"@std/assert": "jsr:@std/assert@^1.0.18"
	},
	"allowScripts": ["npm:argon2@0.44.0"],
	"fmt": {
		"useTabs": true,
		"exclude": ["./target/"]
	},
	"publish": {
		"include": ["LICENSE", "README.md", "lib/**/*.ts", "mod.ts"]
	},
	"exclude": ["./benchmarks/"]
}
